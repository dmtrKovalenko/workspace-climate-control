{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus / Grafana Cloud datasource that receives CO2nsole device samples.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "title": "CO2nsole — Device Health",
  "uid": "co2nsole-health",
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "15s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "tags": [
    "co2nsole",
    "health",
    "reliability"
  ],
  "annotations": {
    "list": []
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Device",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": {
          "query": "label_values(co2nsole_co2_ppm, instance)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "options": []
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Uptime (drops to 0 = reboot)",
      "description": "Sawtooth drops mean the device rebooted — either the task watchdog fired (loop wedge) or the send-failure escalation triggered ESP.restart() after ~10 min of failed pushes.",
      "gridPos": {
        "h": 9,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "co2nsole_uptime_seconds{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "showLegend": false,
          "placement": "bottom",
          "displayMode": "list"
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Free heap",
      "description": "Sustained decline = leak/fragmentation; expect a watchdog reboot when TLS can no longer allocate. Healthy: flat ~50-60 KB.",
      "gridPos": {
        "h": 9,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "co2nsole_heap_free_bytes{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30000
              },
              {
                "color": "green",
                "value": 45000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "showLegend": false,
          "placement": "bottom",
          "displayMode": "list"
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "WiFi RSSI",
      "description": "Below -80 dBm expect send timeouts and gaps. Move the device or the AP closer.",
      "gridPos": {
        "h": 9,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "co2nsole_wifi_rssi_dbm{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dBm",
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": -80
              },
              {
                "color": "green",
                "value": -70
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "showLegend": false,
          "placement": "bottom",
          "displayMode": "list"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Send failures (10m increase)",
      "description": "Counter only reaches Grafana after connectivity recovers — a spike right after a gap quantifies how many pushes failed during the outage. Counter resets to 0 on reboot.",
      "gridPos": {
        "h": 9,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "increase(co2nsole_send_failures_total{instance=~\"$instance\"}[10m])",
          "legendFormat": "{{instance}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "showLegend": false,
          "placement": "bottom",
          "displayMode": "list"
        }
      }
    }
  ]
}
